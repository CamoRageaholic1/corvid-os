#!/bin/sh
# Corvid OS -- auto/config
# ===========================================================================
# Materialises the live-build tree ("lb config"). Runs on any Ubuntu 24.04
# Linux build host with live-build installed (VM, container, cloud instance, or
# bare metal). Validate with `bash -n`; never execute lb on a non-Linux host.
#
# IMPORTANT -- Ubuntu ships the LEGACY live-build 3.0, whose options differ from
# Debian's newer live-build. These flags are what 3.0 actually supports; the
# Debian-style flags the original draft used (--updates, --bootloaders,
# --image-name, --debootstrap-options) are NOT recognised by 3.0:
#   * --bootloader is SINGULAR and set to grub-efi. live-build 3.0's syslinux
#     path is broken on 24.04 (it pulls 2011-era syslinux-themes-ubuntu-oneiric
#     and gfxboot-theme-ubuntu, both long gone). grub-efi builds cleanly, but
#     3.0 emits an ISO with NO El Torito boot record, so auto/build finishes the
#     job with provisioning/remaster-uefi.sh to produce a UEFI-bootable image.
#     The result is UEFI-only, which Ventoy and modern hardware boot fine.
#   * --iso-preparer must not contain a bare "--" (it terminates arg parsing).
#
# The Parrot repo + APT pinning + key are picked up automatically from
# config/archives/*.chroot. Branding stays in one place via the CORVID_* vars.
#
# Build vars:
#   CORVID_SECURITY  true (default) folds in the noble-security pocket; that adds
#                    a long apt-upgrade pass in the binary stage. Set to false
#                    for a much faster dev/smoke build.
#
# "noauto" as the first argument stops lb config from re-sourcing this script.
# ===========================================================================

set -e

lb config noauto \
	--mode ubuntu \
	--distribution noble \
	--architectures amd64 \
	--linux-flavours generic \
	--archive-areas "main restricted universe multiverse" \
	--parent-archive-areas "main restricted universe multiverse" \
	--mirror-bootstrap "http://archive.ubuntu.com/ubuntu/" \
	--mirror-chroot "http://archive.ubuntu.com/ubuntu/" \
	--mirror-chroot-security "http://security.ubuntu.com/ubuntu/" \
	--mirror-binary "http://archive.ubuntu.com/ubuntu/" \
	--mirror-binary-security "http://security.ubuntu.com/ubuntu/" \
	--parent-mirror-bootstrap "http://archive.ubuntu.com/ubuntu/" \
	--parent-mirror-chroot "http://archive.ubuntu.com/ubuntu/" \
	--parent-mirror-chroot-security "http://security.ubuntu.com/ubuntu/" \
	--parent-mirror-binary "http://archive.ubuntu.com/ubuntu/" \
	--parent-mirror-binary-security "http://security.ubuntu.com/ubuntu/" \
	--security "${CORVID_SECURITY:-true}" \
	--backports false \
	--binary-images iso-hybrid \
	--bootloader grub-efi \
	--apt-recommends true \
	--memtest none \
	--bootappend-live "boot=live components username=corvid persistence persistence-encryption=luks" \
	--iso-application "${CORVID_NAME:-Corvid OS}" \
	--iso-volume "${CORVID_NAME:-Corvid} ${CORVID_VERSION:-1.0}" \
	--iso-preparer "Corvid OS project" \
	--iso-publisher "Corvid OS Project (github.com/CamoRageaholic1)" \
	"${@}"

# NOTE (open item): --mode ubuntu produces a casper-based live system, but the
# bootappend above uses Debian live-boot syntax (boot=live / username=). If a
# booted image drops to an initramfs shell instead of the desktop, switch these
# to casper's equivalents (boot=casper, and casper's persistence flag). Pending
# a real boot test to confirm which the live-build 3.0 ubuntu mode expects.
