#!/bin/sh
# Corvid OS -- auto/build
# ===========================================================================
# live-build wrapper. Runs ON THE BUILD VM only (never on macOS).
#
# Flow:
#   (a) Stage branding assets  -- branding/generate-assets.sh rasterizes the
#       SVGs and stages PNGs/os-release/theme text into config/includes.chroot
#       + config/includes.binary. This MUST happen before `lb build`, and a
#       failure here MUST abort the build (otherwise the ISO ships unbranded).
#   (b) `lb build noauto "$@"` -- the real, long (~8-9GB, multi-hour) build.
#       "noauto" stops lb from re-sourcing this script recursively. Output is
#       tee'd to build.log for post-mortem.
#   (c) Stable image name -- live-build emits corvid-amd64.hybrid.iso; publish
#       it also as corvid-amd64.iso (the name SPEC section 5 / smoke-test docs
#       reference) via a symlink, without duplicating the multi-GB file.
# ===========================================================================
set -e

# Locate the repo root from this script's path so the branding step works
# regardless of the caller's working directory. (lb invokes auto/build with the
# config tree root as CWD, which is this same directory.)
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

# ---- (a) branding prep: fail the whole build if it errors -------------------
echo "==> [auto/build] staging branding assets before lb build"
bash "$REPO_ROOT/branding/generate-assets.sh"

# ---- (b) the build. Capture lb's REAL exit status through the tee pipe. -----
# /bin/sh on the Ubuntu build VM is dash, which has no `set -o pipefail`, so a
# pipeline's status is tee's (always 0). Record lb build's own status via a
# temp file. `set +e` around the pipeline guarantees the status line runs even
# when lb build fails (otherwise `set -e` would kill the subshell first).
_status_file=$(mktemp)
set +e
{ lb build noauto "$@"; echo "$?" > "$_status_file"; } 2>&1 | tee build.log
set -e
_status=$(cat "$_status_file" 2>/dev/null || echo 1)
rm -f "$_status_file"

if [ "$_status" -ne 0 ]; then
	echo "==> [auto/build] lb build failed (exit $_status); see build.log" >&2
	exit "$_status"
fi

# ---- (c) stable image name: corvid-amd64.iso -> corvid-amd64.hybrid.iso -----
# lb runs with the config tree root as CWD, so the image lands here next to
# build.log. Symlink (don't copy) to avoid duplicating an ~8-9GB file.
_hybrid="corvid-amd64.hybrid.iso"
_stable="corvid-amd64.iso"
if [ -f "$_hybrid" ]; then
	ln -sf "$_hybrid" "$_stable"
	echo "==> [auto/build] published $_stable -> $_hybrid"
elif [ -f "$_stable" ]; then
	echo "==> [auto/build] $_stable already present (no hybrid variant to link)"
else
	# Naming can drift across live-build versions; don't fail a good build,
	# but make the mismatch loud so the builder can fix the link.
	_found=$(ls -1 corvid-*.iso 2>/dev/null | head -n 1 || true)
	if [ -n "$_found" ]; then
		ln -sf "$_found" "$_stable"
		echo "==> [auto/build] published $_stable -> $_found (fallback match)"
	else
		echo "==> [auto/build] WARNING: build succeeded but no corvid-*.iso found to link as $_stable" >&2
	fi
fi
