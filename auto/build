#!/bin/sh
# Corvid OS -- auto/build
# ===========================================================================
# live-build wrapper. Runs on the Linux build host only (never on macOS).
#
# Flow:
#   (a) Stage branding assets  -- branding/generate-assets.sh rasterizes the
#       SVGs and stages PNGs/os-release/theme text into config/includes.chroot
#       + config/includes.binary. This MUST happen before `lb build`, and a
#       failure here MUST abort the build (otherwise the ISO ships unbranded).
#   (b) `lb build noauto "$@"` -- the real, long build. Output is tee'd to
#       build.log. NOTE: on Ubuntu's live-build 3.0 the grub-efi build finishes
#       the data ISO but then exits NON-ZERO on an obsolete `isohybrid` step
#       (which only matters for legacy BIOS). We treat that as non-fatal as long
#       as the data ISO was produced.
#   (c) Remaster into a bootable UEFI image -- live-build 3.0 emits an ISO with
#       no El Torito boot record, so provisioning/remaster-uefi.sh adds a GRUB
#       EFI boot record and writes the final corvid-amd64.iso.
# ===========================================================================
set -e

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

# ---- (a) branding prep: fail the whole build if it errors -------------------
echo "==> [auto/build] staging branding assets before lb build"
bash "$REPO_ROOT/branding/generate-assets.sh"

# ---- (b) the build. Capture lb's REAL exit status through the tee pipe. -----
# /bin/sh on the Ubuntu build host is dash (no `pipefail`), so capture lb's own
# status via a temp file rather than trusting the pipeline's (tee's) status.
_status_file=$(mktemp)
set +e
{ lb build noauto "$@"; echo "$?" > "$_status_file"; } 2>&1 | tee build.log
set -e
_status=$(cat "$_status_file" 2>/dev/null || echo 1)
rm -f "$_status_file"

# ---- (c) locate the produced data ISO --------------------------------------
# live-build 3.0 may exit non-zero on the obsolete isohybrid step but still
# leave the data ISO behind (as live-image-*.hybrid.iso, or the intermediate
# chroot/binary.hybrid.iso). Find whichever exists.
_data=""
for _c in live-image-amd64.hybrid.iso corvid-amd64.hybrid.iso binary.hybrid.iso chroot/binary.hybrid.iso; do
	if [ -f "$_c" ]; then _data="$_c"; break; fi
done

if [ -z "$_data" ]; then
	echo "==> [auto/build] lb build failed (exit $_status) and produced no ISO; see build.log" >&2
	exit "${_status:-1}"
fi
if [ "$_status" -ne 0 ]; then
	echo "==> [auto/build] lb build exited $_status (expected: live-build 3.0's obsolete isohybrid step); data ISO present at $_data, continuing" >&2
fi

# ---- (d) remaster into a UEFI-bootable Corvid ISO ---------------------------
echo "==> [auto/build] remastering $_data -> corvid-amd64.iso (UEFI boot record)"
sh "$REPO_ROOT/provisioning/remaster-uefi.sh" "$_data" "corvid-amd64.iso"
echo "==> [auto/build] done: corvid-amd64.iso"
