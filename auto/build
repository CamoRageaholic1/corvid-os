#!/bin/sh
# Corvid OS -- auto/build
# ===========================================================================
# live-build wrapper. Runs on the Linux build host only (never on macOS).
#
# Flow:
#   (a) Stage branding assets (branding/generate-assets.sh). Must succeed.
#   (b) Neutralize live-build 3.0's broken ISO step. Its genisoimage caps files
#       at 4 GiB (our squashfs is larger), it writes no El Torito boot record,
#       and it calls a missing isohybrid. We skip it (an early `exit 0` marked
#       CORVID-SKIP) so the `binary/` staging tree survives intact.
#   (c) Run `lb build`. Bootstraps, installs, runs hooks, builds the squashfs
#       into binary/, and (thanks to (b)) stops short of the broken ISO step.
#   (d) Master the real UEFI-bootable ISO from binary/ with
#       provisioning/remaster-uefi.sh, which uses `xorriso -iso-level 3` for
#       native >4 GiB support plus a proper UEFI El Torito boot record.
# ===========================================================================
set -e

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

# ---- (a) branding prep: fail the whole build if it errors -------------------
echo "==> [auto/build] staging branding assets before lb build"
bash "$REPO_ROOT/branding/generate-assets.sh"

# ---- (b) neutralize live-build's broken ISO step (keeps binary/ intact) -----
LB_ISO=/usr/lib/live/build/lb_binary_iso
if [ -w "$LB_ISO" ] && ! grep -q 'CORVID-SKIP' "$LB_ISO"; then
	_tmp=$(mktemp)
	{ head -n 1 "$LB_ISO"; echo 'exit 0  # CORVID-SKIP: ISO mastered by remaster-uefi.sh from binary/'; tail -n +2 "$LB_ISO"; } > "$_tmp"
	cat "$_tmp" > "$LB_ISO"
	rm -f "$_tmp"
	echo "==> [auto/build] neutralized live-build binary_iso (CORVID-SKIP)"
fi

# ---- (c) the build. Capture lb's real exit status through the tee pipe. ------
_status_file=$(mktemp)
set +e
{ lb build noauto "$@"; echo "$?" > "$_status_file"; } 2>&1 | tee build.log
set -e
_status=$(cat "$_status_file" 2>/dev/null || echo 1)
rm -f "$_status_file"
if [ "$_status" -ne 0 ]; then
	echo "==> [auto/build] lb build failed (exit $_status); see build.log" >&2
	exit "$_status"
fi

# ---- (d) master the UEFI-bootable ISO from the binary/ tree ------------------
if [ ! -e binary/casper/filesystem.squashfs ] && [ ! -e binary/live/filesystem.squashfs ]; then
	echo "==> [auto/build] binary/ squashfs missing after lb build; cannot master ISO" >&2
	exit 1
fi
echo "==> [auto/build] mastering corvid-amd64.iso from binary/ (xorriso -iso-level 3)"
sh "$REPO_ROOT/provisioning/remaster-uefi.sh" binary corvid-amd64.iso
echo "==> [auto/build] done: corvid-amd64.iso"
