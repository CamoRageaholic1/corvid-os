install_goose() {
    header "Goose (Block — local AI agent)"
    need curl "Install it with:  sudo apt install curl" || return 1
    say "This runs Block's official Goose installer (downloads the 'goose' binary and"
    say "sets it up under your home directory)."
    say "Project: https://github.com/block/goose"
    if run "curl -fsSL https://github.com/block/goose/releases/download/stable/download_cli.sh | bash"; then
        ok "Goose installed."
        hint "Start it with:  goose        (open a new shell first if it isn't on PATH yet)"
        return 0
    fi
    warn "Official installer failed — trying pipx as a fallback."
    if have pipx && run "pipx install goose-ai"; then
        ok "Goose installed via pipx (package: goose-ai)."
        hint "Start it with:  goose"
        return 0
    fi
    err "Goose install failed."
    say "Install manually from:  https://block.github.io/goose/docs/getting-started/installation"
    return 1
}

