install_jan() {
    header "Jan (offline AI assistant)"
    need curl "Install it with:  sudo apt install curl" || return 1

    dest_dir="${HOME}/.local/bin"
    dest="${dest_dir}/Jan.AppImage"
    mkdir -p "${dest_dir}"

    # Jan ships Linux as an AppImage from its GitHub releases. Resolve the latest
    # AppImage asset URL from the GitHub API (no hardcoded version).
    api="https://api.github.com/repos/menloresearch/jan/releases/latest"
    say "Resolving the latest Jan AppImage from GitHub releases ..."
    dl="$(curl -fsSL "${api}" 2>/dev/null | grep -oE 'https://[^"]+\.AppImage' | head -n1)"

    if [ -n "${dl}" ]; then
        say "Downloading Jan AppImage to ${dest}"
        if run "curl -fL --progress-bar '${dl}' -o '${dest}'" && [ -s "${dest}" ]; then
            chmod +x "${dest}"
            ok "Jan saved to ${dest} and made executable."
            hint "Start it with:  Jan.AppImage    (~/.local/bin is on your PATH)"
            say "  - AppImages need FUSE. If it won't launch:  ${dest} --appimage-extract-and-run"
            return 0
        fi
        rm -f "${dest}" 2>/dev/null || true
    fi

    err "Automatic download failed (the release layout may have changed)."
    say "Do this manually instead:"
    say "  1. Open  https://jan.ai/download  and download the Linux AppImage."
    say "  2. chmod +x ~/Downloads/jan-*.AppImage"
    say "  3. mv     ~/Downloads/jan-*.AppImage  ${dest}"
    return 1
}

