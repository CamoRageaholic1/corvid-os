    header "opencode (terminal AI coding agent)"
    need curl "Install it with:  sudo apt install curl" || return 1
    say "This runs the official opencode installer."
    say "Project: https://opencode.ai"
    if run "curl -fsSL https://opencode.ai/install | bash"; then
        ok "opencode installed."
        hint "Start it with:  opencode     (open a new shell first if it isn't on PATH yet)"
        return 0
    fi
    warn "Official installer failed — trying the npm package as a fallback."
    if need npm "Install Node.js/npm with:  sudo apt install nodejs npm" && npm_global_install "opencode-ai"; then
        ok "opencode installed via npm (package: opencode-ai)."
        hint "Start it with:  opencode"
        return 0
    fi
    err "opencode install failed."
    return 1
}

install_copilot_cli() {
    header "GitHub Copilot CLI (gh extension)"
    need gh "Install the GitHub CLI first:  sudo apt install gh   (or see https://cli.github.com)" || return 1
    say "This adds the Copilot extension to the GitHub CLI. You must be logged in"
    say "('gh auth login') and have Copilot access on your GitHub account."
    if run "gh extension install github/gh-copilot"; then
        ok "GitHub Copilot CLI installed."
        hint "Suggest a command:  gh copilot suggest \"...\""
        hint "Explain a command:  gh copilot explain \"...\""
        return 0
    fi
    err "GitHub Copilot CLI install failed."
    return 1
}

install_cursor() {
    header "Cursor (AI-first IDE)"
    need curl "Install it with:  sudo apt install curl" || return 1

    dest_dir="${HOME}/.local/bin"
    dest="${dest_dir}/Cursor.AppImage"
    mkdir -p "${dest_dir}"

    # Cursor ships Linux as an AppImage. Their download API returns a JSON blob
    # with the current stable AppImage URL, so we don't hardcode a version.
    api="https://www.cursor.com/api/download?platform=linux-x64&releaseTrack=stable"
    say "Resolving the latest Cursor AppImage URL from cursor.com ..."
    dl=""
    if have jq; then
        dl="$(curl -fsSL "${api}" 2>/dev/null | jq -r '.downloadUrl // .url // empty' 2>/dev/null)"
    fi
    if [ -z "${dl}" ]; then
        # Fallback: pull the first AppImage URL out of the response without jq.
        dl="$(curl -fsSL "${api}" 2>/dev/null | grep -oE 'https://[^"]+\.AppImage' | head -n1)"
    fi

    if [ -n "${dl}" ]; then
        say "Downloading Cursor AppImage to ${dest}"
        if run "curl -fL --progress-bar '${dl}' -o '${dest}'" && [ -s "${dest}" ]; then
            chmod +x "${dest}"
            ok "Cursor saved to ${dest} and made executable."
            hint "Start it with:  Cursor.AppImage    (~/.local/bin is on your PATH)"
            say "  - AppImages need FUSE. If it won't launch:  ${dest} --appimage-extract-and-run"
            return 0
        fi
        rm -f "${dest}" 2>/dev/null || true
    fi

    err "Automatic download failed (the API or URL may have changed)."
    say "Do this manually instead:"
    say "  1. Open  https://www.cursor.com/downloads  and download the Linux (x64) AppImage."
    say "  2. chmod +x ~/Downloads/Cursor-*.AppImage"
    say "  3. mv     ~/Downloads/Cursor-*.AppImage  ${dest}"
    say "     (~/.local/bin is already on Corvid's PATH, so it becomes 'Cursor.AppImage')"
    return 1
}

install_windsurf() {
    header "Windsurf (Codeium's AI IDE)"
    need curl "Install it with:  sudo apt install curl" || return 1

    if have apt-get && have sudo; then
        say "Installing Windsurf from Codeium's apt repository (Debian/Ubuntu)."
        say "Docs: https://windsurf.com/editor/download"
        key="https://windsurf-stable.codeiumdata.com/wVxQEIWkwPUEAGf3/windsurf.gpg"
        keyring="/usr/share/keyrings/windsurf-stable-archive-keyring.gpg"
        listline="deb [signed-by=${keyring} arch=amd64] https://windsurf-stable.codeiumdata.com/wVxQEIWkwPUEAGf3/apt stable main"
        if run "curl -fsSL '${key}' | sudo gpg --dearmor -o '${keyring}'" \
           && run "echo '${listline}' | sudo tee /etc/apt/sources.list.d/windsurf.list >/dev/null" \
           && run "sudo apt-get update" \
           && run "sudo apt-get install -y windsurf"; then
            ok "Windsurf installed."
            hint "Start it with:  windsurf"
            return 0
        fi
        warn "apt-repo install failed (their repo path may have changed)."
    fi

    err "Automatic install failed."
    say "Install manually instead:"
    say "  1. Open  https://windsurf.com/editor/download  and grab the Linux build (.deb or tarball)."
    say "  2. .deb:     sudo apt install ./windsurf-*.deb"
    say "     tarball:  extract it and run the 'windsurf' launcher inside."
    return 1
}

install_vscode_ai_ext() {
    header "VS Code AI extensions (Cline + Continue)"
    need code "Install VS Code first to get the 'code' command (e.g. sudo apt install code), then re-run this." || return 1
    total=0; good=0
    for ext in "saoudrizwan.claude-dev" "Continue.continue"; do
        total=$((total + 1))
        if run "code --install-extension ${ext}"; then
            good=$((good + 1))
        fi
    done
    printf '\n'
    if [ "$good" -eq "$total" ]; then
        ok "Installed both VS Code AI extensions (Cline + Continue)."
        hint "Open VS Code and look for the Cline and Continue icons in the sidebar."
        return 0
    fi
    warn "Installed ${good}/${total} extensions. Review the messages above."
    return 1
}

install_llm() {
    header "llm (Simon Willison's LLM CLI)"
    if ! need pipx "Install it with:  python3 -m pip install --user pipx && pipx ensurepath"; then
        return 1
    fi
    if run "pipx install llm"; then
        ok "llm installed."
        hint "Start it with:  llm \"your prompt\""
        say "Next steps:"
        say "  - Store an API key:         llm keys set openai"
        say "  - Use local Ollama models:  llm install llm-ollama"
        return 0
    fi
    err "llm install failed."
    return 1
}

install_mods() {
    header "mods (Charmbracelet — AI on the command line)"
    say "mods pipes shell output through an LLM. Two supported install paths:"
    say "  a) Charm's apt repo (Debian/Ubuntu .deb)    b) 'go install' (needs Go)"

    # Path A: Charm's apt repo. Needs sudo + apt (Corvid is Debian-based) + gpg.
    if have apt-get && have sudo && have curl; then
        say ""
        say "Trying Charm's apt repository..."
        if run "sudo mkdir -p /etc/apt/keyrings" \
           && run "curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg" \
           && run "echo 'deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *' | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null" \
           && run "sudo apt-get update" \
           && run "sudo apt-get install -y mods"; then
            ok "mods installed via Charm's apt repo."
            hint "Try it with:  ls | mods \"explain these files\""
            return 0
        fi
        warn "apt-repo install failed — falling back to 'go install'."
    fi

    # Path B: go install.
    if need go "Go ships in Corvid's dev stack. Install it with:  sudo apt install golang-go"; then
        if run "go install github.com/charmbracelet/mods@latest"; then
            ok "mods installed via 'go install' (into \$(go env GOPATH)/bin — usually ~/go/bin)."
            hint "Make sure that bin dir is on PATH, then run:  mods \"your prompt\""
            return 0
        fi
    fi

    err "mods install failed."
    say "Install manually from:  https://github.com/charmbracelet/mods"
    return 1
}

