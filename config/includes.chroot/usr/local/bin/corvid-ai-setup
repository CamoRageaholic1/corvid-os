#!/usr/bin/env bash
# ============================================================================
# corvid-ai-setup  —  install AI coding agents & local LLM runtimes
# ----------------------------------------------------------------------------
# Corvid OS flagship "agentic OS" tool. This is a RUNTIME installer: it runs on
# the live/installed system when the USER launches it, NOT at image build time.
# It installs nothing on its own until the user picks something from the menu.
#
# The base image already ships nodejs+npm, python3+pipx, curl and git (from the
# devstack hook 0400), so this script only needs to shell out to those.
#
# Design goals:
#   - Plain numbered TUI that works over a bare terminal (colors degrade to none
#     when stdout is not a tty or tput is unavailable).
#   - Never hard-fail the whole menu because one tool's install broke — each
#     action reports its own success/failure and returns to the menu.
#   - Show the exact command before running it, so the user learns the real
#     install method instead of trusting a black box.
#
# NOTE: no `set -e` on purpose — a failed install must drop back to the menu,
# not kill the program.
# ============================================================================

set -u

# ---------------------------------------------------------------------------
# Colors — light touch, graceful degradation.
# ---------------------------------------------------------------------------
if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ] 2>/dev/null; then
    BOLD="$(tput bold)"; RESET="$(tput sgr0)"
    RED="$(tput setaf 1)"; GREEN="$(tput setaf 2)"; YELLOW="$(tput setaf 3)"
    BLUE="$(tput setaf 4)"; CYAN="$(tput setaf 6)"
else
    BOLD=""; RESET=""; RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""
fi

# ---------------------------------------------------------------------------
# Little print helpers.
# ---------------------------------------------------------------------------
say()    { printf '%s\n' "$*"; }
info()   { printf '%s\n' "${BLUE}$*${RESET}"; }
ok()     { printf '%s\n' "${GREEN}[ ok ]${RESET} $*"; }
warn()   { printf '%s\n' "${YELLOW}[warn]${RESET} $*" >&2; }
err()    { printf '%s\n' "${RED}[fail]${RESET} $*" >&2; }
hint()   { printf '%s\n' "${CYAN}  ->${RESET} $*"; }
header() { printf '\n%s\n' "${BOLD}== $* ==${RESET}"; }

have()   { command -v "$1" >/dev/null 2>&1; }

# need CMD [advice] — returns non-zero and warns if CMD is missing.
need() {
    _cmd="$1"; _advice="${2:-}"
    if have "$_cmd"; then
        return 0
    fi
    err "Required tool '${_cmd}' is not installed."
    [ -n "$_advice" ] && say "     $_advice"
    return 1
}

# run "command string" — print the exact command, then execute it.
run() {
    printf '%s %s\n' "${CYAN}Running:${RESET}" "$1"
    eval "$1"
}

pause() {
    printf '\n%s' "Press Enter to return to the menu... "
    read -r _ || true
}

# ---------------------------------------------------------------------------
# npm global install with fallbacks.
#   1. plain `npm install -g`
#   2. `sudo npm install -g`  (if sudo exists)
#   3. user-writable prefix under ~/.local  (its bin is already on Corvid PATH)
# ---------------------------------------------------------------------------
npm_global_install() {
    pkg="$1"
    if run "npm install -g ${pkg}"; then
        return 0
    fi
    warn "Global npm install failed (usually the npm prefix is not user-writable)."

    if have sudo; then
        say "Retrying with sudo (you may be prompted for your password)..."
        if run "sudo npm install -g ${pkg}"; then
            return 0
        fi
        warn "sudo install also failed."
    fi

    prefix="${HOME}/.local"
    say "Retrying with a user-writable npm prefix at ${prefix} ..."
    mkdir -p "${prefix}"
    if run "npm install -g --prefix ${prefix} ${pkg}"; then
        ok "Installed into ${prefix} (its bin dir is already on Corvid's PATH)."
        return 0
    fi

    err "All npm install strategies failed for ${pkg}."
    say "  Manual options:"
    say "    - Fix the global prefix:  npm config set prefix ~/.local  (then re-run)"
    say "    - Or install with sudo:   sudo npm install -g ${pkg}"
    return 1
}

# ---------------------------------------------------------------------------
# Individual installers. Each returns 0 on success, non-zero on failure.
# ---------------------------------------------------------------------------

install_claude_code() {
    header "Claude Code (Anthropic)"
    need npm "Node.js/npm ships with Corvid — reinstall it with: sudo apt install nodejs npm" || return 1
    if npm_global_install "@anthropic-ai/claude-code"; then
        ok "Claude Code installed."
        hint "Start it with:  claude"
        return 0
    fi
    return 1
}

install_codex() {
    header "OpenAI Codex CLI"
    need npm "Node.js/npm ships with Corvid — reinstall it with: sudo apt install nodejs npm" || return 1
    if npm_global_install "@openai/codex"; then
        ok "OpenAI Codex CLI installed."
        hint "Start it with:  codex"
        return 0
    fi
    return 1
}

install_gemini() {
    header "Google Gemini CLI"
    need npm "Node.js/npm ships with Corvid — reinstall it with: sudo apt install nodejs npm" || return 1
    if npm_global_install "@google/gemini-cli"; then
        ok "Google Gemini CLI installed."
        hint "Start it with:  gemini"
        return 0
    fi
    return 1
}

install_aider() {
    header "Aider (AI pair programmer)"
    if ! need pipx "Install it with:  python3 -m pip install --user pipx && pipx ensurepath"; then
        return 1
    fi
    if run "pipx install aider-chat"; then
        ok "Aider installed."
        hint "Start it in a git repo with:  aider"
        return 0
    fi
    err "Aider install failed."
    return 1
}

install_ollama() {
    header "Ollama (local LLM runtime)"
    need curl "Install it with:  sudo apt install curl" || return 1
    say "This runs Ollama's official installer. It may ask for sudo to install the"
    say "systemd service and place the 'ollama' binary under /usr/local/bin."
    if run "curl -fsSL https://ollama.com/install.sh | sh"; then
        ok "Ollama installed."
        hint "Pull & chat with a model:  ollama run llama3"
        hint "List installed models:     ollama list"
        return 0
    fi
    err "Ollama install failed."
    return 1
}

install_lmstudio() {
    header "LM Studio (local LLM GUI)"
    need curl "Install it with:  sudo apt install curl" || return 1

    # LM Studio ships the desktop app as a Linux AppImage. Their documented
    # "latest" redirect resolves to the current x64 AppImage, so we don't have
    # to hardcode a version. If that download fails (offline, URL changed), we
    # fall back to guiding the user to the download page.
    url="https://lmstudio.ai/download/latest/linux/x64?format=AppImage"
    dest_dir="${HOME}/.local/bin"
    dest="${dest_dir}/LM-Studio.AppImage"

    mkdir -p "${dest_dir}"
    say "Downloading the LM Studio AppImage to ${dest}"
    if run "curl -fL --progress-bar '${url}' -o '${dest}'" && [ -s "${dest}" ]; then
        chmod +x "${dest}"
        ok "LM Studio saved to ${dest} and made executable."
        hint "Start it with:  LM-Studio.AppImage    (~/.local/bin is on your PATH)"
        say "Notes:"
        say "  - AppImages need FUSE. If it won't launch, run it once with:"
        say "        ${dest} --appimage-extract-and-run"
        say "  - LM Studio also has a headless CLI ('lms'):  curl -fsSL https://lmstudio.ai/install.sh | bash"
        return 0
    fi

    err "Automatic download failed."
    say "Do this manually instead:"
    say "  1. Open  https://lmstudio.ai/download  in a browser and download the Linux AppImage."
    say "  2. chmod +x ~/Downloads/LM-Studio-*.AppImage"
    say "  3. mv     ~/Downloads/LM-Studio-*.AppImage  ${dest}"
    say "     (~/.local/bin is already on Corvid's PATH, so it becomes 'LM-Studio.AppImage')"
    rm -f "${dest}" 2>/dev/null || true
    return 1
}

install_hermes() {
    header "Hermes (Nous Research self-improving agent)"
    need curl "Install it with:  sudo apt install curl" || return 1
    say "This runs the official Nous Research installer. It clones the hermes-agent"
    say "repo, builds a Python venv, pulls its deps, and adds a global 'hermes' command."
    say "Project: https://github.com/NousResearch/hermes-agent"
    if run "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash"; then
        ok "Hermes installed."
        hint "First-time auth:  hermes setup --portal"
        hint "Then run it with: hermes"
        return 0
    fi
    err "Hermes install failed."
    say "You can install it manually from:  https://github.com/NousResearch/hermes-agent"
    return 1
}

