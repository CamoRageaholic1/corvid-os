    if run "pipx install open-webui"; then
        ok "Open WebUI installed."
        hint "Start it with:  open-webui serve      (then open http://localhost:8080)"
        return 0
    fi
    err "Open WebUI install failed."
    say "Note: Open WebUI needs Python 3.11+. You can also run it in Docker:"
    say "  docker run -d -p 8080:8080 -v open-webui:/app/backend/data --name open-webui ghcr.io/open-webui/open-webui:main"
    return 1
}

