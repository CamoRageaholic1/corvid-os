        say "  fabric --setup      (interactive: pick a model + pull the patterns)"
        say "  fabric -U           (update/download the latest patterns)"
        hint "Run a pattern with:  pbpaste | fabric -p <pattern>   (e.g. fabric -p summarize)"
        return 0
    fi
    err "fabric install failed."
    say "Install manually from:  https://github.com/danielmiessler/fabric"
    return 1
}

install_mcp_servers() {
    header "Popular MCP servers (Model Context Protocol)"
    need npm "Node.js/npm ships with Corvid — reinstall it with: sudo apt install nodejs npm" || return 1
    say "Installing a vetted set of MCP servers globally via npm. These plug extra"
    say "tools into MCP-aware agents (Claude Code, etc.)."
    servers="@modelcontextprotocol/server-filesystem \
@modelcontextprotocol/server-git \
@modelcontextprotocol/server-github \
@modelcontextprotocol/server-memory \
@modelcontextprotocol/server-sequential-thinking \
@playwright/mcp"
    total=0; good=0
    for pkg in $servers; do
        total=$((total + 1))
        if npm_global_install "${pkg}"; then
            good=$((good + 1))
        fi
    done
    printf '\n'
    if [ "$good" -eq "$total" ]; then
        ok "All ${total} MCP servers installed."
    else
        warn "Installed ${good}/${total} MCP servers. Review the messages above."
    fi
    say ""
    say "Register them with Claude Code (run once each; tweak paths/args to taste):"
    say "  claude mcp add filesystem           -- npx -y @modelcontextprotocol/server-filesystem \$HOME"
    say "  claude mcp add git                  -- npx -y @modelcontextprotocol/server-git"
    say "  claude mcp add github               -- npx -y @modelcontextprotocol/server-github"
    say "  claude mcp add memory               -- npx -y @modelcontextprotocol/server-memory"
    say "  claude mcp add sequential-thinking  -- npx -y @modelcontextprotocol/server-sequential-thinking"
    say "  claude mcp add playwright           -- npx -y @playwright/mcp"
    hint "List what's registered:  claude mcp list"
    say "  (server-github needs a GITHUB_TOKEN in its env to reach private repos.)"
    return 0
}

install_corvid_skills() {
    header "Corvid Skills library"
    need git "Install it with:  sudo apt install git" || return 1
    dest="${HOME}/corvid-skills"
    if [ -d "${dest}/.git" ]; then
        say "Found an existing checkout at ${dest} — updating it."
        if run "git -C '${dest}' pull --ff-only"; then
            ok "Corvid Skills library updated at ${dest}."
            hint "Read the guide:  less ${dest}/README.md"
            return 0
        fi
        err "Update failed."
        return 1
    fi
    if run "git clone https://github.com/CamoRageaholic1/corvid-skills '${dest}'"; then
        ok "Corvid Skills library cloned to ${dest}."
        say "Curated agent skills, prompts, MCP configs, and templates live here."
        hint "Start by reading:  less ${dest}/README.md"
        return 0
    fi
    err "Clone failed."
    return 1
}

install_all_cli() {
    header "Install all CLI agents (Claude Code, Codex, Gemini, Aider)"
    total=0; good=0
    for fn in install_claude_code install_codex install_gemini install_aider; do
        total=$((total + 1))
        if "$fn"; then
            good=$((good + 1))
        fi
    done
    printf '\n'
    if [ "$good" -eq "$total" ]; then
        ok "All ${total} CLI agents installed."
    else
        warn "Installed ${good}/${total} CLI agents. Review the messages above for any failures."
    fi
}

# ---------------------------------------------------------------------------
# Menu / main loop.
# ---------------------------------------------------------------------------
prereq_line() {
    _line="Prerequisites:"
    for _t in npm pipx curl git go; do
        if have "$_t"; then
            _line="${_line} ${GREEN}${_t}${RESET}"
        else
            _line="${_line} ${RED}${_t}(missing)${RESET}"
        fi
    done
    printf '%s\n' "$_line"
}

print_menu() {
    clear 2>/dev/null || true
    cat <<EOF
${BOLD}${CYAN}==============================================================${RESET}
${BOLD} Corvid AI Setup -- install AI agents & LLM runtimes${RESET}
${BOLD}${CYAN}==============================================================${RESET}

  Pick a number to install it. You can install several in a row.

  ${BOLD}CLI coding agents${RESET}
    1) Claude Code (Anthropic)      npm    -> claude
    2) OpenAI Codex CLI             npm    -> codex
    3) Google Gemini CLI            npm    -> gemini
    4) Aider (AI pair programmer)   pipx   -> aider
    5) OpenHands (autonomous agent) pipx   -> openhands
    6) Goose (Block)                script -> goose
    7) opencode                     script -> opencode
    8) GitHub Copilot CLI           gh ext -> gh copilot

  ${BOLD}AI IDEs & editors${RESET}
    9) Cursor (AI IDE)              AppImage -> Cursor.AppImage
   10) Windsurf (Codeium IDE)       apt      -> windsurf
   11) VS Code AI extensions        code ext -> Cline + Continue

  ${BOLD}Terminal LLM tools${RESET}
   12) llm (Simon Willison)         pipx   -> llm
   13) mods (Charmbracelet)         apt/go -> mods
   14) shell-gpt (sgpt)             pipx   -> sgpt

  ${BOLD}Local LLM runtimes${RESET}
   15) Ollama (local LLM runtime)   script   -> ollama run llama3
   16) LM Studio (local LLM GUI)    AppImage -> LM-Studio.AppImage
   17) Hermes (Nous Research agent) script   -> hermes
   18) Jan (offline AI)             AppImage -> Jan.AppImage
   19) Open WebUI (local chat UI)   pipx     -> open-webui serve

  ${BOLD}Skills & tools${RESET}
   20) fabric (AI patterns library) go     -> fabric -p <pattern>
   21) Popular MCP servers          npm    -> claude mcp add ...
   22) Corvid Skills library        git    -> ~/corvid-skills

  ${BOLD}Convenience${RESET}
   23) Install ALL CLI agents (1-4)

    q) Quit

EOF
    prereq_line
    printf '\n'
}

main() {
    while true; do
        print_menu
        printf '%s' "${BOLD}corvid-ai>${RESET} Choose [1-23, q]: "
        if ! read -r choice; then
            printf '\n'
            break
        fi
        # trim surrounding whitespace
        choice="$(printf '%s' "$choice" | tr -d '[:space:]')"
        case "$choice" in
            1)  install_claude_code;  pause ;;
            2)  install_codex;        pause ;;
            3)  install_gemini;       pause ;;
            4)  install_aider;        pause ;;
            5)  install_openhands;    pause ;;
            6)  install_goose;        pause ;;
            7)  install_opencode;     pause ;;
            8)  install_copilot_cli;  pause ;;
            9)  install_cursor;       pause ;;
            10) install_windsurf;     pause ;;
            11) install_vscode_ai_ext; pause ;;
            12) install_llm;          pause ;;
            13) install_mods;         pause ;;
            14) install_shell_gpt;    pause ;;
            15) install_ollama;       pause ;;
            16) install_lmstudio;     pause ;;
            17) install_hermes;       pause ;;
            18) install_jan;          pause ;;
            19) install_open_webui;   pause ;;
            20) install_fabric;       pause ;;
            21) install_mcp_servers;  pause ;;
            22) install_corvid_skills; pause ;;
            23) install_all_cli;      pause ;;
            q|Q|quit|exit) say "Bye."; break ;;
            "") : ;;  # empty input: redraw
            *) warn "Unknown choice: '${choice}'"; pause ;;
        esac
    done
}

main "$@"
